# ──────────────────────────────────────
# Next.js env vars (see docs/env-convention.md)
# ──────────────────────────────────────

# API Base URL (Next.js exposes NEXT_PUBLIC_* to the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# E2E (Playwright) — only used in CI / local e2e runs
E2E_USERNAME=testuser
E2E_PASSWORD=testpass123
E2E_API_URL=http://localhost:8000
E2E_BASE_URL=http://localhost:3000
