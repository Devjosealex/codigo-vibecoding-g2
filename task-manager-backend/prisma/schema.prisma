generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  lastname  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  tasks     Task[]

  @@map("users")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  userId      Int?     @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  @@map("tasks")
}